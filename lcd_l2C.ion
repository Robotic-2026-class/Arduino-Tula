
#include <LiquidCrystal.h>

LiquidCrystal lcd(12, 11, 5, 4, 3, 2);

const int sensorPin = A0;

void setup() {
  lcd.begin(16, 2); 
  lcd.print("Sensor Value:");
}

void loop() {
  int sensorValue = analogRead(sensorPin);
  
  int percentage = map(sensorValue, 0, 1023, 0, 100);

  lcd.setCursor(0, 1); 
  lcd.print("Level: ");
  lcd.print(percentage);
  lcd.print("%    "); 
  
  delay(100);
}
